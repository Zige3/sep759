<h1 class="mb-3">Countries</h1>

<div class="card mb-4">
  <div class="card-body">
    <p class="text-muted">
      Search a country name (example:
      <code>can</code>,
      <code>china</code>,
      <code>united</code>)
    </p>

    <%= form_with url: root_path, method: :get, local: true do %>
      <div class="form-row align-items-end">
        <div class="col-12 col-md-6 mb-2">
          <%= label_tag :looking_for, "Search:", class: "font-weight-bold" %>
          <%= text_field_tag :looking_for,
                @query,
                placeholder: "e.g., canada",
                class: "form-control" %>
        </div>

        <div class="col-12 col-md-3 mb-2">
          <%= submit_tag "Search", class: "btn btn-primary btn-block" %>
        </div>
      </div>
    <% end %>

    <% if @query.blank? %>
      <p class="mt-3 text-muted">
        <em>Please search using the box above.</em>
      </p>
    <% end %>
  </div>
</div>


<% if @countries.any? %>
  <div class="card">
    <div class="card-body">

      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="thead-light">
            <tr>
              <th style="width:70px;">Flag</th>
              <th>Name</th>
              <th class="d-none d-md-table-cell">Region</th>
              <th class="d-none d-md-table-cell">Capital</th>
              <th style="width:90px;">Details</th>
            </tr>
          </thead>

          <tbody>
            <% @countries.each do |c| %>
              <tr>
                <td>
                  <% if c[:flag_png].present? %>
                    <%= image_tag c[:flag_png],
                          alt: "#{c[:name_common]} flag",
                          class: "flag-img" %>
                  <% else %>
                    N/A
                  <% end %>
                </td>

                <td class="font-weight-semibold">
                  <%= c[:name_common] %>
                </td>

                <td class="d-none d-md-table-cell">
                  <span class="badge badge-secondary">
                    <%= c[:region] %>
                  </span>
                </td>

                <td class="d-none d-md-table-cell">
                  <%= c[:capital].presence || "—" %>
                </td>

                <td>
                  <%= link_to "View",
                        details_path(code: c[:cca3], looking_for: @query),
                        class: "btn btn-sm btn-outline-primary" %>
                </td>
              </tr>
            <% end %>
          </tbody>

        </table>
      </div>

    </div>
  </div>

<% elsif @query.present? %>
  <div class="alert alert-warning mt-3">
    No results found.
  </div>
<% end %>